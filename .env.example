# Copy to .env and set values. Used by: docker compose (moderate service).
# Optional: leave OIDC_* empty to run moderator without login (local dev).
# For Phase 7 / assignment demo: set OIDC_* and run with --profile oidc.

# --- Database (default: MySQL) ---
# DB_TYPE=mysql
# DB_TYPE=mongo
# MONGO_URI=mongodb://172.28.0.12:27017/jokedb

# --- Phase 7: OIDC for moderator (Keycloak) ---
# Get these after creating realm "jokes" and client "moderate-app" in Keycloak (http://localhost:8080).
# OIDC_ISSUER_BASE_URL=http://localhost:8080/realms/jokes
# OIDC_ISSUER_INTERNAL_URL=http://keycloak:8080/realms/jokes
# OIDC_BASE_URL=http://localhost:4100
# OIDC_CLIENT_ID=moderate-app
# OIDC_CLIENT_SECRET=<from Keycloak client credentials>
# OIDC_SECRET=<any long random string for session encryption>
