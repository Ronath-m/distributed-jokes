# Database (Phase 1–5). Joke + ETL use DB_TYPE to pick adapter.
DB_HOST=172.28.0.10
DB_PORT=3306
DB_USER=jokeuser
DB_PASSWORD=jokepass
DB_NAME=jokedb

# Phase 5 – dual DB: mysql (default) or mongo
# DB_TYPE=mysql
# For MongoDB (joke + ETL only):
# DB_TYPE=mongo
# MONGO_URI=mongodb://172.28.0.12:27017/jokedb

# RabbitMQ (Phase 2+)
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
# SUBMIT_QUEUE=submit

# Submit: joke service URL for types + file cache (Phase 2+)
# JOKE_SERVICE_URL=http://joke:3000
# TYPES_CACHE_PATH=/data/types.json

# Service URLs (when behind Kong or separate VMs)
# KONG_PUBLIC_URL=https://your-kong-ip
